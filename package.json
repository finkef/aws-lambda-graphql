{
  "name": "aws-lambda-graphql",
  "version": "1.0.4",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "description": "Apollo server for AWS Lambda with WebSocket subscriptions support over API Gateway v1 + v2",
  "sideEffects": false,
  "keywords": [
    "apollo",
    "aws",
    "lambda",
    "graphql",
    "subscriptions",
    "apigateway",
    "websocket",
    "http",
    "graphql-subscriptions",
    "serverless"
  ],
  "dependencies": {
    "@types/aws-lambda": "^8.10.36",
    "apollo-server-core": "^2.9.14",
    "apollo-server-lambda": "^2.9.14",
    "graphql": "^15.5.0",
    "graphql-subscriptions": "^1.1.0",
    "iterall": "^1.2.2",
    "ulid": "^2.3.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.848.0",
    "@aws-sdk/client-dynamodb": "^3.848.0",
    "@aws-sdk/lib-dynamodb": "^3.850.0",
    "@aws-sdk/util-dynamodb": "^3.848.0"
  },
  "devDependencies": {
    "@babel/core": "^7.7.2",
    "@babel/plugin-proposal-class-properties": "^7.7.0",
    "@babel/plugin-proposal-class-static-block": "^7.21.0",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-class-static-block": "^7.27.1",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/preset-env": "^7.7.1",
    "@babel/preset-react": "^7.7.0",
    "@babel/preset-typescript": "^7.7.2",
    "@commitlint/cli": "^8.3.5",
    "@commitlint/config-conventional": "^8.3.4",
    "@types/jest": "^29.5.14",
    "@types/node": "10.17.5",
    "@types/node-fetch": "^2.5.4",
    "@typescript-eslint/eslint-plugin": "^2.8.0",
    "@typescript-eslint/parser": "^2.8.0",
    "all-contributors-cli": "^6.11.2",
    "babel-jest": "^29.7.0",
    "eslint": "^6.6.0",
    "eslint-config-airbnb-typescript": "^6.3.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.18.2",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-react": "^7.16.0",
    "eslint-plugin-react-hooks": "^1.7.0",
    "husky": "^3.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^9.4.3",
    "prettier": "^2.0.5",
    "rimraf": "^3.0.0",
    "ts-jest": "^29.4.0",
    "typescript": "^4.9.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*.{json,md}": [
      "prettier --write",
      "git add"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "lint": "eslint --ext ts src",
    "lint-staged": "lint-staged",
    "test": "jest",
    "test:ci": "jest --ci --runInBand",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  }
}
